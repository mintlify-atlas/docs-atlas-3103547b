  "keyFeatures": [
    "Multi-project and git worktree management",
    "AI chat with Claude CLI, Codex CLI, and OpenCode support",
    "Magic commands for PR creation, code review, and commit messages",
    "GitHub integration with issue and PR investigation",
    "Built-in terminal and developer tools",
    "Remote web access with HTTP server and WebSocket support",
    "Session management with archiving and recovery",
    "Customizable themes, fonts, and keyboard shortcuts"
  ],
  "publicApiSurface": [
    "Projects API - create, list, update, delete projects",
    "Worktrees API - create, archive, restore worktrees",
    "Sessions API - manage chat sessions and execution modes",
    "Chat API - send messages, stream responses",
    "Magic commands - investigate_issue, investigate_pr, create_pr, code_review, commit_message",
    "GitHub integration - checkout PRs, investigate workflows",
    "Terminal API - open terminals in worktrees",
    "Preferences API - customize settings and keybindings"
  ]
